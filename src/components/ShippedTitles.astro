---
<section class="shipped" id="shipped">
  <h2>Shipped Shows & Apps</h2>
  <div class="grid">
    {titles.map(title => (
      <div 
        class={`title-card ${title.youtubeId ? 'has-video' : ''} ${title.storeUrl ? 'has-store' : ''}`} 
        data-video-id={title.youtubeId}
        data-store-url={title.storeUrl}
      >
        <div class="image-container">
          <img src={title.image} alt={title.name} loading="lazy" />
          {title.youtubeId && (
            <div class="play-overlay">
              <div class="action-button">
                <svg viewBox="0 0 24 24" fill="currentColor" class="play-icon">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
          )}
          {title.storeUrl && !title.youtubeId && (
            <div class="play-overlay">
              <div class="action-button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="store-icon">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </div>
            </div>
          )}
        </div>
        <div class="hover-overlay">
          <p class="contribution">{title.contribution}</p>
        </div>
        <div class="info">
          <h3>{title.name}</h3>
          <p>{title.platform} | {title.year}</p>
          <span class="company">{title.company}</span>
        </div>
      </div>
    ))}
  </div>

  <div id="video-modal" class="modal">
    <div class="modal-backdrop"></div>
    <div class="modal-content">
      <button class="close-modal">&times;</button>
      <div class="video-wrapper">
        <div id="player"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const modal = document.getElementById('video-modal');
  const cards = document.querySelectorAll('.title-card');
  const closeBtn = document.querySelector('.close-modal');
  const backdrop = document.querySelector('.modal-backdrop');
  const playerContainer = document.getElementById('player');

  const openModal = (videoId) => {
    if (!modal || !playerContainer) return;
    
    playerContainer.innerHTML = `
      <iframe 
        width="100%" 
        height="100%" 
        src="https://www.youtube.com/embed/${videoId}?autoplay=1" 
        title="YouTube video player" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen>
      </iframe>
    `;
    
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    if (!modal || !playerContainer) return;
    modal.classList.remove('active');
    playerContainer.innerHTML = '';
    document.body.style.overflow = '';
  };

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const videoId = card.getAttribute('data-video-id');
      const storeUrl = card.getAttribute('data-store-url');
      
      if (videoId) {
        openModal(videoId);
      } else if (storeUrl) {
        window.open(storeUrl, '_blank');
      }
    });
  });

  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (backdrop) backdrop.addEventListener('click', closeModal);

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>

<style>
  .shipped {
    margin: 0 0 120px;
    padding: 0;
  }
  h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    margin-bottom: 60px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
  }
  .title-card {
    position: relative;
    transition: var(--transition);
  }
  .title-card.has-video,
  .title-card.has-store {
    cursor: pointer;
  }
  .image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 15px;
    border: 1px solid var(--border);
  }
  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition);
    filter: grayscale(20%);
  }
  
  .play-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: var(--transition);
  }

  .action-button {
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transform: scale(0.8);
    transition: var(--transition);
  }

  .action-button svg {
    width: 30px;
    height: 30px;
  }

  .play-icon {
    margin-left: 4px;
  }

  .title-card:hover .image-container img {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  .title-card:hover .play-overlay {
    opacity: 0; /* Hide play button when showing details */
  }

  .hover-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 25px;
    opacity: 0;
    transition: var(--transition);
    z-index: 20;
    text-align: center;
    border-radius: 4px;
    border: 1px solid var(--accent);
    pointer-events: none;
    transform: translateY(10px);
  }

  .title-card:hover .hover-overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .contribution {
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
    font-weight: 500;
  }

  .title-card:hover .action-button {
    transform: scale(1);
    background: var(--accent);
    color: var(--bg);
  }

  h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
  }
  p {
    margin: 5px 0;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .company {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
    opacity: 0.6;
  }

  /* Modal Styles */
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    visibility: hidden;
    opacity: 0;
    transition: var(--transition);
  }

  .modal.active {
    visibility: visible;
    opacity: 1;
  }

  .modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
  }

  .modal-content {
    position: relative;
    width: 90%;
    max-width: 1000px;
    background: #000;
    z-index: 1001;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
  }

  .video-wrapper :global(iframe) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .close-modal {
    position: absolute;
    top: -50px;
    right: 0;
    background: none;
    border: none;
    color: white;
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    transition: var(--transition);
  }

  .close-modal:hover {
    color: var(--accent);
    transform: scale(1.1);
  }

  @media (max-width: 768px) {
    .close-modal {
      top: 10px;
      right: 10px;
      z-index: 1002;
      background: rgba(0,0,0,0.5);
      border-radius: 50%;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }
  }
</style>
