---
const skillCategories = [
  {
    name: "Languages",
    skills: ["C++", "C#", "Lua", "Python"]
  },
  {
    name: "Engines",
    skills: ["Unreal Engine 4/5", "Unity", "Godot"]
  },
  {
    name: "Engineering",
    skills: ["System Architecture", "Real-Time Systems", "Multiplayer Networking", "Online Backend", "Multithreading"]
  },
  {
    name: "Technical",
    skills: ["Profiling", "RenderDoc", "Rapid Prototyping", "Editor Tools", "CI/CD"]
  },
  {
    name: "Tools",
    skills: ["Git", "Perforce", "Visual Studio", "BuildGraph", "Docker"]
  }
];
---
<section class="skills-sidebar">
  <h2>Skills</h2>
  <div class="categories">
    {skillCategories.map(category => (
      <div class="category">
        <h3>{category.name}</h3>
        <div class="tags">
          {category.skills.map(skill => (
            <span class="tag">{skill}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-sidebar {
    padding: 0;
  }
  h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    margin-bottom: 30px;
  }
  .categories {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  .category h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 15px;
    color: var(--text);
    font-weight: 700;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    font-size: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 4px;
    color: var(--text-muted);
    transition: var(--transition);
    font-weight: 500;
  }
  .tag:hover {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }
</style>
