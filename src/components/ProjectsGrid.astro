---
import { getCollection } from 'astro:content';
const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---
<section class="projects">
  <h2>Technical Projects</h2>
  <div class="grid">
    {sortedProjects.map((project) => (
      <div class="project-card">
        <h3>{project.data.title}</h3>
        <div class="tech-stack">
          {project.data.tech.map(t => <span>{t}</span>)}
        </div>
        <p>{project.body.split('\n')[0]}</p>
        {project.data.link && <a href={project.data.link} target="_blank">View Project</a>}
      </div>
    ))}
  </div>
</section>

<style>
  .projects { max-width: 900px; margin: 80px auto; padding: 0 20px; }
  h2 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-muted); border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 40px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
  @media (max-width: 768px) { .grid { grid-template-columns: 1fr; } }
  .project-card { border: 1px solid var(--border); padding: 25px; border-radius: 4px; }
  h3 { margin: 0 0 10px; font-size: 1.25rem; }
  .tech-stack { margin-bottom: 15px; display: flex; flex-wrap: wrap; gap: 8px; }
  .tech-stack span { font-size: 0.7rem; background: var(--border); padding: 2px 8px; border-radius: 2px; color: var(--text-muted); }
  p { color: var(--text-muted); line-height: 1.6; font-size: 0.9rem; }
  a { display: inline-block; margin-top: 15px; color: var(--accent); text-decoration: none; font-weight: 600; font-size: 0.9rem; }
</style>
