---
import { getCollection } from 'astro:content';
const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---
<section class="projects">
  <h2>Technical Projects</h2>
  <div class="grid">
    {sortedProjects.map((project) => (
      <div class="project-card">
        {project.data.image && (
          <div class="image-container">
            <img src={project.data.image} alt={project.data.title} loading="lazy" />
          </div>
        )}
        <div class="card-content">
          <h3>{project.data.title}</h3>
          <div class="tech-stack">
            {project.data.tech.map(t => <span>{t}</span>)}
          </div>
          <p>{project.body.split('\n')[0]}</p>
          {project.data.link && (
            <a href={project.data.link} target="_blank" class="project-link">
              View Repository <span class="arrow">→</span>
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .projects {
    max-width: 900px;
    margin: 120px auto;
    padding: 0 20px;
  }
  h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    margin-bottom: 60px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }
  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
  }
  .project-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }
  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
  }
  .image-container {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition);
  }
  .project-card:hover .image-container img {
    transform: scale(1.05);
  }
  .card-content {
    padding: 25px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  h3 {
    margin: 0 0 10px;
    font-size: 1.5rem;
    font-weight: 700;
  }
  .tech-stack {
    margin-bottom: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tech-stack span {
    font-size: 0.7rem;
    background: var(--border);
    padding: 3px 10px;
    border-radius: 4px;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  p {
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: 25px;
    flex-grow: 1;
  }
  .project-link {
    display: inline-flex;
    align-items: center;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    gap: 8px;
    transition: var(--transition);
  }
  .project-link:hover {
    color: var(--accent);
  }
  .project-link:hover .arrow {
    transform: translateX(4px);
  }
  .arrow {
    transition: var(--transition);
  }
</style>
