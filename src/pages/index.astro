---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import ShippedTitles from '../components/ShippedTitles.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import Skills from '../components/Skills.astro';
import Education from '../components/Education.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Hemal Patel | Senior Gameplay & Systems Engineer">
  <main>
    <Hero />
    
    <div class="content-layout">
      <div class="main-content">
        <Experience />
        <ShippedTitles />
        <ProjectsGrid />
        <Education />
      </div>
      <aside class="sidebar">
        <div class="sticky-content">
          <Skills />
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .content-layout {
    max-width: 100%;
    margin: 80px auto 0;
    display: grid;
    grid-template-columns: 1fr 900px 1fr;
    gap: 0;
  }

  .main-content {
    grid-column: 2;
    width: 100%;
    padding: 0 20px;
  }

  .sidebar {
    grid-column: 3;
    padding-left: 80px;
    width: 380px; /* 300px skills + 80px gap */
  }

  .sticky-content {
    position: sticky;
    top: 60px;
    width: 300px;
  }

  @media (max-width: 1400px) {
    .content-layout {
      grid-template-columns: 1fr 800px 1fr;
    }
    .main-content {
      max-width: 800px;
    }
    .sidebar {
      padding-left: 40px;
      width: 340px;
    }
  }

  @media (max-width: 1200px) {
    .content-layout {
      display: block;
      max-width: 900px;
      margin: 80px auto 0;
      padding: 0 20px;
    }
    .sidebar {
      width: 100%;
      padding-left: 0;
      margin-top: 80px;
    }
    .sticky-content {
      position: static;
      width: 100%;
    }
  }
</style>
