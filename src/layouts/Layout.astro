---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-TMB7WW66E6"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-TMB7WW66E6');
		</script>
	</head>
	<body>
		<div class="glow-container">
			<div class="glow glow-1"></div>
			<div class="glow glow-2"></div>
		</div>
		<slot />

		<!-- Global Video Modal -->
		<div id="video-modal" class="global-modal">
			<div class="modal-backdrop"></div>
			<div class="modal-content">
				<div class="video-wrapper">
					<div id="player"></div>
				</div>
				<button class="close-modal" aria-label="Close video">&times;</button>
			</div>
		</div>

		<script is:inline>
			const modal = document.getElementById('video-modal');
			const closeBtn = modal?.querySelector('.close-modal');
			const backdrop = modal?.querySelector('.modal-backdrop');
			const playerContainer = document.getElementById('player');

			const openModal = (videoId) => {
				if (!modal || !playerContainer) return;
				
				playerContainer.innerHTML = `
					<iframe 
						width="100%" 
						height="100%" 
						src="https://www.youtube.com/embed/${videoId}?autoplay=1" 
						title="YouTube video player" 
						frameborder="0" 
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
						allowfullscreen>
					</iframe>
				`;
				
				modal.classList.add('active');
				document.body.style.overflow = 'hidden';
				document.body.classList.add('modal-open');
			};

			const closeModal = () => {
				if (!modal || !playerContainer) return;
				modal.classList.remove('active');
				playerContainer.innerHTML = '';
				document.body.style.overflow = '';
				document.body.classList.remove('modal-open');
			};

			// Global Event Listener
			window.addEventListener('play-video', (e) => {
				if (e.detail && e.detail.videoId) {
					openModal(e.detail.videoId);
				}
			});

			closeBtn?.addEventListener('click', closeModal);
			backdrop?.addEventListener('click', closeModal);
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') closeModal();
			});
		</script>
	</body>
</html>
<style is:global>
	:root {
		--bg: #0a0a0a;
		--text: #ffffff;
		--text-muted: #a3a3a3;
		--accent: #ffffff;
		--border: #262626;
		--glow-1: rgba(59, 130, 246, 0.08); /* Blue */
		--glow-2: rgba(147, 51, 234, 0.08); /* Purple */
		--transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}
	* {
		box-sizing: border-box;
	}
	html {
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
		background: var(--bg);
		color: var(--text);
		scroll-behavior: smooth;
	}
	body {
		margin: 0;
		padding: 0;
		line-height: 1.6;
		position: relative;
		overflow-x: hidden;
	}
	
	/* Glow Effects */
	.glow-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}
	.glow {
		position: absolute;
		width: 60vw;
		height: 60vw;
		border-radius: 50%;
		filter: blur(120px);
		animation: pulse 15s infinite alternate ease-in-out;
	}
	.glow-1 {
		top: -20%;
		right: -10%;
		background: var(--glow-1);
	}
	.glow-2 {
		bottom: -20%;
		left: -10%;
		background: var(--glow-2);
		animation-delay: -7s;
	}

	@keyframes pulse {
		0% { transform: scale(1); opacity: 0.5; }
		50% { transform: scale(1.1); opacity: 0.8; }
		100% { transform: scale(1); opacity: 0.5; }
	}

	h1, h2, h3, h4 {
		letter-spacing: -0.02em;
	}

	/* Animations */
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.fade-in {
		animation: fadeIn 0.8s ease-out forwards;
	}

	section {
		opacity: 0;
		animation: fadeIn 0.8s ease-out forwards;
		animation-delay: 0.2s;
	}

	/* Utility */
	.btn {
		display: inline-block;
		padding: 12px 24px;
		background: var(--accent);
		color: var(--bg);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.9rem;
		border-radius: 4px;
		transition: var(--transition);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.btn:hover {
		opacity: 0.9;
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(255,255,255,0.1);
	}

	/* Global Modal Styles */
	.global-modal {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		visibility: hidden;
		opacity: 0;
		transition: all 0.3s ease;
		pointer-events: none;
	}

	.global-modal.active {
		visibility: visible;
		opacity: 1;
		pointer-events: auto;
	}

	.modal-backdrop {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0, 0, 0, 0.95);
		backdrop-filter: blur(10px);
		cursor: pointer;
	}

	.modal-content {
		position: relative;
		width: 90%;
		max-width: 1100px;
		background: #000;
		border-radius: 8px;
		box-shadow: 0 0 50px rgba(0, 0, 0, 1);
		border: 1px solid #333;
		z-index: 10000;
	}

	.video-wrapper {
		position: relative;
		width: 100%;
		padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
		height: 0;
		overflow: hidden;
		border-radius: 8px;
	}

	#player {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}

	#player iframe {
		width: 100%;
		height: 100%;
		display: block;
		border: none;
	}

	.close-modal {
		position: absolute;
		top: -50px;
		right: 0;
		background: none;
		border: none;
		color: white;
		font-size: 2.5rem;
		cursor: pointer;
		line-height: 1;
		padding: 10px;
		transition: var(--transition);
	}

	.close-modal:hover {
		color: var(--accent);
		transform: scale(1.1);
	}

	@media (max-width: 768px) {
		.modal-content {
			width: 95%;
		}
		.close-modal {
			top: -45px;
			font-size: 2rem;
		}
	}
</style>
